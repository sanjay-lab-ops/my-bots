# ── Ignore everything by default ─────────────────────────────────
*

# ── Only allow bot folders and shared files ───────────────────────
!trading_automation/
!trading_automation/**
!VISHU_ELITE_BOT/
!VISHU_ELITE_BOT/**
!VISHU_SMC_BOT/
!VISHU_SMC_BOT/**
!VISHU_SCALP_BOT/
!VISHU_SCALP_BOT/**
!cross_bot_lock.py
!START_3_BOTS.bat
!README.md
!.gitignore
!requirements.txt
!.env.example

# ── Block secrets and state files inside bot folders ─────────────
**/.env
**/*.env
**/placed_today.json
**/session_traded.json
**/cross_bot_active.json
**/balance_history.json
**/placed_this_run.json
**/milestones_today.json
**/running_balance.json
**/close_on_profit.json
**/__pycache__/
**/*.pyc
**/*.log
